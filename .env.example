# --- Docker Compose runtime ---
POSTGRES_DB=kiotviet_taphoa
POSTGRES_USER=app_user
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_WEBHOOK_BASE_URL=http://localhost:5678/
GENERIC_TIMEZONE=Asia/Ho_Chi_Minh

# --- App / integration variables from PRD ---
DATABASE_URL=postgresql://app_user:change_me@localhost:5432/kiotviet_taphoa
ZALO_APP_ID=YOUR_ZALO_APP_ID
ZALO_OA_SECRET=YOUR_ZALO_OA_SECRET
ZALO_OA_ACCESS_TOKEN=BOOTSTRAP_ONLY_REFRESH_LATER
KIOTVIET_CLIENT_ID=YOUR_KIOTVIET_CLIENT_ID
KIOTVIET_CLIENT_SECRET=YOUR_KIOTVIET_CLIENT_SECRET
KIOTVIET_RETAILER=YOUR_RETAILER_NAME
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
LOG_LEVEL=info

OPS_ALERT_WEBHOOK_URL=https://example.com/hooks/ops-summary

# --- Security / validation / retention ---
WEBHOOK_REPLAY_WINDOW_SECONDS=300
ALLOWED_FILE_URL_HOSTS=
MIN_CUSTOM_PRICE=100
MAX_CUSTOM_PRICE=1000000000
INVOICE_PARSED_DATA_RETENTION_DAYS=180
OPS_EVENTS_RETENTION_DAYS=90

TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
