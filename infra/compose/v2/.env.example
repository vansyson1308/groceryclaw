# V2 local compose environment template (development only)

NODE_ENV=development
LOG_LEVEL=info

# Gateway is the ONLY host-exposed service in local V2 compose.
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080

# Admin remains private (no host port mapping in compose).
# Keep bound to loopback/private interface by default.
ADMIN_HOST=127.0.0.1
ADMIN_PORT=3001
ADMIN_ENABLED=true
ADMIN_OIDC_ISSUER=https://issuer.example
ADMIN_OIDC_AUDIENCE=groceryclaw-admin
ADMIN_OIDC_JWKS_URI=http://127.0.0.1:18082/.well-known/jwks.json
ADMIN_OIDC_ROLES_CLAIM=roles
ADMIN_BREAKGLASS_ENABLED=false
# ADMIN_BREAKGLASS_API_KEY=replace-me
ADMIN_BREAKGLASS_SCOPE=read_only
ADMIN_TENANT_ENDPOINTS_ENABLED=true
ADMIN_INVITE_PEPPER=replace-me
ADMIN_INVITE_TTL_HOURS=72
ADMIN_INVITE_RATE_PER_TENANT_PER_MINUTE=10
ADMIN_SECRETS_ENABLED=true
# 32-byte key base64; dev only. Never commit real keys.
ADMIN_MEK_B64=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# Worker has no host exposure.
WORKER_HOST=0.0.0.0
WORKER_PORT=3002

POSTGRES_DB=groceryclaw_v2
POSTGRES_USER=groceryclaw
POSTGRES_PASSWORD=groceryclaw_dev

REDIS_PASSWORD=redis_dev_password

V2_GATEWAY_WEBHOOK_ENABLED=true

# Webhook authenticity defaults (Mode 1 in all environments by default)
WEBHOOK_VERIFY_MODE=mode1
WEBHOOK_SIGNATURE_SECRET=replace-me-local
WEBHOOK_SIGNATURE_HEADERS=x-zalo-signature

# Mode 2 fallback controls (staging-only by default; blocked in production unless override=true)
WEBHOOK_MODE2_TOKEN=replace-me-local-mode2
WEBHOOK_MODE2_TOKEN_HEADER=x-webhook-token
WEBHOOK_MODE2_ALLOW_IN_PRODUCTION=false
WEBHOOK_MODE2_GLOBAL_RATE_PER_MINUTE=300
WEBHOOK_MODE2_PER_IP_RATE_PER_MINUTE=60
WEBHOOK_MODE2_PER_PLATFORM_USER_RATE_PER_MINUTE=30
WEBHOOK_MODE2_ATTACHMENT_ALLOWLIST=zalo.me,zadn.vn

# Optional timestamp enforcement (only valid when WEBHOOK_VERIFY_MODE=mode1 and signed timestamp is verified)
WEBHOOK_ENFORCE_TIMESTAMP=false
WEBHOOK_TIMESTAMP_HEADER=x-zalo-timestamp
WEBHOOK_TIMESTAMP_MAX_DRIFT_SECONDS=300

WEBHOOK_REPLAY_TTL_SECONDS=86400

V2_ONBOARDING_ENABLED=true
INVITE_PEPPER_HEX=replace-me-hex
# INVITE_PEPPER_B64=replace-me-base64
ONBOARDING_INVITE_USER_RATE_PER_MINUTE=10
ONBOARDING_INVITE_IP_RATE_PER_MINUTE=20
WORKER_METRICS_HOST=127.0.0.1
WORKER_METRICS_PORT=9090
WORKER_CONCURRENCY=5
WORKER_XML_PARSE_ENABLED=true
WORKER_XML_ALLOWED_DOMAINS=zalo.me,zadn.vn
WORKER_XML_MAX_BYTES=1048576
WORKER_XML_TIMEOUT_MS=10000
WORKER_MAPPING_ENABLED=true
WORKER_KIOTVIET_SYNC_ENABLED=true
KIOTVIET_SYNC_MAX_RETRIES=3
KIOTVIET_SYNC_BACKOFF_MS=200
KIOTVIET_TIMEOUT_MS=2000
KIOTVIET_STUB_BASE_URL=http://127.0.0.1:18080
KIOTVIET_STUB_TOKEN=stub-token
WORKER_MEK_B64=${ADMIN_MEK_B64}
WORKER_NOTIFIER_ENABLED=true
NOTIFIER_MAX_MESSAGE_LENGTH=500
NOTIFIER_RATE_LIMIT_ENABLED=true
NOTIFIER_GLOBAL_RATE_PER_MINUTE=120
NOTIFIER_TENANT_RATE_PER_MINUTE=30
NOTIFIER_USER_BURST=5
NOTIFIER_DLQ_ENABLED=true
NOTIFIER_MAX_ATTEMPTS=4
NOTIFIER_RETRY_BASE_MS=500
NOTIFIER_RETRY_MAX_MS=10000
WORKER_INTERACTION_WINDOW_ENFORCED=true
WORKER_INTERACTION_WINDOW_SECONDS=86400
WORKER_PENDING_TTL_SECONDS=604800
WORKER_MAX_PENDING_PER_USER=20
WORKER_FLUSH_PENDING_ENABLED=true
WORKER_FLUSH_BATCH_SIZE=20
WORKER_FLUSH_MAX_PER_RUN=50
WORKER_FLUSH_RATE_PER_MINUTE=60
ZALO_STUB_BASE_URL=http://127.0.0.1:18081
ZALO_STUB_TOKEN=stub-zalo-token
ZALO_STUB_TIMEOUT_MS=2000
