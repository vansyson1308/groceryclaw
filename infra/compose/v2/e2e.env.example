# E2E compose environment template (no secrets committed)
# The E2E runner generates a temporary env file with ephemeral secrets at runtime.

NODE_ENV=test
LOG_LEVEL=info
ENABLE_QUEUE_IN_TEST=true
WORKER_XML_ALLOWED_DOMAINS=xml-stub
WORKER_XML_ALLOW_HTTP_DOMAINS=xml-stub
POSTGRES_DB=groceryclaw_v2_e2e
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=<SET_AT_RUNTIME>
APP_DB_USER=app_user
APP_DB_PASSWORD=<SET_AT_RUNTIME>
REDIS_PASSWORD=<SET_AT_RUNTIME>
REDIS_URL=redis://:<SET_AT_RUNTIME>@redis:6379/0
WEBHOOK_SIGNATURE_SECRET=<SET_AT_RUNTIME>
INVITE_PEPPER_B64=<SET_AT_RUNTIME_BASE64_32_BYTES>
ADMIN_MEK_B64=<SET_AT_RUNTIME_BASE64_32_BYTES>
WORKER_MEK_B64=<SET_AT_RUNTIME_BASE64_32_BYTES>
ADMIN_BREAKGLASS_API_KEY=<SET_AT_RUNTIME>
KIOTVIET_STUB_TOKEN=<SET_AT_RUNTIME>
ZALO_STUB_TOKEN=<SET_AT_RUNTIME>
