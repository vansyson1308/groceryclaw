{
  "name": "Draft PO Decision Handler",
  "nodes": [
    {
      "parameters": {},
      "id": "1",
      "name": "Execute Workflow Trigger",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1,
      "position": [220, 320]
    },
    {
      "parameters": {
        "jsCode": "const i = $json || {};\nconst payload = String(i.payload || i.button_payload || '').trim();\nlet action = String(i.action || '').trim();\nlet zalo_user_id = String(i.zalo_user_id || '').trim();\nlet zalo_msg_id = String(i.zalo_msg_id || '').trim();\nlet draft_po_id = i.draft_po_id != null ? Number(i.draft_po_id) : null;\n\nif (payload) {\n  const [a, user, msg, po] = payload.split('|');\n  if (!action) action = String(a || '').trim();\n  if (!zalo_user_id) zalo_user_id = String(user || '').trim();\n  if (!zalo_msg_id) zalo_msg_id = String(msg || '').trim();\n  if (draft_po_id == null && po) draft_po_id = Number(po);\n}\n\nconst allowed = new Set(['DRAFT_APPROVE', 'DRAFT_REJECT', 'DRAFT_EDIT', 'DRAFT_CUSTOM_PRICE']);\nif (!allowed.has(action)) throw new Error('Unsupported action');\nif (!zalo_user_id || !zalo_msg_id || !Number.isFinite(draft_po_id)) throw new Error('Missing required IDs (zalo_user_id, zalo_msg_id, draft_po_id)');\n\nconst text_input = String(i.text_input || i.message_text || '').trim();\nif (action === 'DRAFT_CUSTOM_PRICE') {\n  const v = Number(text_input.replace(',', '.'));\n  if (!text_input || !Number.isFinite(v) || v <= 0) throw new Error('Custom price must be a positive number');\n}\n\nreturn [{ json: { action, zalo_user_id, zalo_msg_id, draft_po_id, text_input } }];"
      },
      "id": "2",
      "name": "Parse and Validate Decision",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 320]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT session_state, context_data, expires_at FROM user_sessions WHERE zalo_user_id='{{$json.zalo_user_id}}' ORDER BY updated_at DESC LIMIT 1;"
      },
      "id": "3",
      "name": "Load User Session",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [700, 320],
      "credentials": {
        "postgres": {
          "id": "__SET_IN_N8N__",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const req = $('Parse and Validate Decision').item.json;\nconst row = $json || {};\nconst ctx = typeof row.context_data === 'string' ? JSON.parse(row.context_data) : (row.context_data || {});\nif (!row.session_state) throw new Error('No active session for this user');\nif (row.session_state !== 'waiting_for_draft_confirm') throw new Error(`Invalid session_state ${row.session_state}`);\nif (ctx.zalo_msg_id !== req.zalo_msg_id) throw new Error('Session zalo_msg_id mismatch');\nif (Number(ctx.draft_po_id) !== Number(req.draft_po_id)) throw new Error('Session draft_po_id mismatch');\nif (row.expires_at && new Date(row.expires_at) < new Date()) throw new Error('Session expired');\nreturn [{ json: { ...req, session_context: ctx } }];"
      },
      "id": "4",
      "name": "Validate Session Context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [940, 320]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT id, status, decision_status, decision_payload, kiotviet_po_id, kiotviet_po_code FROM invoice_log WHERE zalo_user_id='{{$json.zalo_user_id}}' AND zalo_msg_id='{{$json.zalo_msg_id}}' ORDER BY created_at DESC LIMIT 1;"
      },
      "id": "5",
      "name": "Load invoice_log",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [1180, 320],
      "credentials": {
        "postgres": {
          "id": "__SET_IN_N8N__",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const req = $('Validate Session Context').item.json;\nconst inv = $json || {};\nif (!inv.id) throw new Error('invoice_log row not found');\nconst decision = inv.decision_status || 'pending';\nconst payload = typeof inv.decision_payload === 'string' ? JSON.parse(inv.decision_payload) : (inv.decision_payload || {});\nif (Number(payload.draft_po_id || req.draft_po_id) !== Number(req.draft_po_id)) throw new Error('invoice_log draft_po_id mismatch');\nconst alreadyProcessed = decision !== 'pending';\nreturn [{ json: { ...req, invoice_id: Number(inv.id), current_decision_status: decision, already_processed: alreadyProcessed, draft_po_code: payload.draft_po_code || req.session_context.draft_po_code || '', total_amount: Number(payload.total || 0) } }];"
      },
      "id": "6",
      "name": "Decision Replay Guard",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1420, 320]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "version": 2,
            "leftValue": "",
            "caseSensitive": true,
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "a",
              "leftValue": "={{$json.already_processed}}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equal"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "7",
      "name": "Already Processed?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [1660, 320]
    },
    {
      "parameters": {
        "jsCode": "return [{ json: { status: 'already_processed', decision_status: $json.current_decision_status, invoice_id: $json.invoice_id } }];"
      },
