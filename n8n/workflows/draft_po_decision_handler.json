      "parameters": {
        "jsCode": "const ctx = $('Decision Replay Guard').item.json;\nreturn [{ json: { recipient: { user_id: ctx.zalo_user_id }, message: { text: `✅ Đã duyệt PO nháp ${ctx.draft_po_code || ctx.draft_po_id}. Hệ thống đã chốt phiếu nhập.` } } }];"
      },
      "id": "15",
      "name": "Build Approve Reply",
      "type": "n8n-nodes-base.code",
