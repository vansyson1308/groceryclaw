            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { status: 2, description: 'Approved from Draft PO flow', totalPayment: $('Decision Replay Guard').item.json.total_amount || 0, payments: [{ method: 'cash', amount: $('Decision Replay Guard').item.json.total_amount || 0 }] } }}"
      },
      "id": "11",
      "name": "Finalize Draft PO",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2360, 420]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE invoice_log SET status='completed', decision_status='approved', decision_at=NOW(), decision_payload=COALESCE(decision_payload, '{}'::jsonb) || jsonb_build_object('action','DRAFT_APPROVE','approved_by','{{$json.zalo_user_id}}','approved_at',NOW()::text) WHERE id={{$json.invoice_id}} AND decision_status='pending' RETURNING id;"
      },
