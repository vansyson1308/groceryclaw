              "name": "scopes",
              "value": "PublicApi.Access"
            }
          ]
        }
      },
      "id": "17",
      "name": "Get KiotViet Token",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2310,
        220
      ]
    },
    {
      "parameters": {
        "jsCode": "const token = $('Get KiotViet Token').item.json.access_token;\nconst target = $('Build PUT Body').item.json.update_target;\nconst putBody = $('Build PUT Body').item.json.put_body;\nif (!token) throw new Error('missing kiotviet token');\nconst url = `https://public.kiotviet.vn/api/products/${target.product_id}`;\nconst headers = {\n  Authorization: `Bearer ${token}`,\n  Retailer: $env.KIOTVIET_RETAILER,\n  'Content-Type': 'application/json'\n};\n\nlet lastErr = null;\nfor (let attempt = 0; attempt < 4; attempt++) {\n  try {\n    const res = await this.helpers.httpRequest({ method: 'PUT', url, json: true, body: putBody, headers });\n    return [{ json: { ...$('Build PUT Body').item.json, update_result: res, retries: attempt } }];\n  } catch (err) {\n    const code = Number(err?.statusCode || 0);\n    if (code === 429 || code >= 500) {\n      const backoffMs = Math.pow(2, attempt) * 1000;\n      await new Promise((r) => setTimeout(r, backoffMs));\n      lastErr = err;\n      continue;\n    }\n    throw err;\n  }\n}\nthrow lastErr || new Error('PUT update failed after retries');"
      },
      "id": "18",
      "name": "PUT Product Price with Retry",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2540,
        220
      ]
    },
