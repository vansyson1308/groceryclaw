      "parameters": {
        "jsCode": "const target = $json.update_target;\nif (!target || !target.product_id) throw new Error('Missing update target');\nreturn [{ json: { ...$json, put_body: { basePrice: Number(target.new_price) } } }];"
      },
      "id": "16",
      "name": "Build PUT Body",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
