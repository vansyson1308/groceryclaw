      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO invoice_log (zalo_user_id, supplier_code, source_type, source_url, parsed_data, status, error_details, created_at) VALUES ('{{$json.zalo_user_id}}', 'pricing_decision', 'xml', 'workflow://price_update_handler', jsonb_build_object('decision', 'price_update', 'product_id', {{$json.update_target.product_id}}, 'new_price', {{$json.update_target.new_price}}), 'completed', NULL, NOW());"
      },
