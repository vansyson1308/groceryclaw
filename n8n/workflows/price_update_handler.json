    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE user_sessions\nSET session_state='waiting_for_custom_price',\n    context_data=jsonb_set(context_data, '{pending_custom}', jsonb_build_object('product_id', {{$json.update_target.product_id}}, 'suggested_price', {{$json.update_target.suggested_price}}), true),\n    expires_at=NOW() + INTERVAL '30 minutes',\n    updated_at=NOW()\nWHERE id={{$json.session_id}};"
      },
