{
  "name": "Price Update Handler",
  "nodes": [
    {
      "parameters": {},
      "id": "1",
      "name": "Execute Workflow Trigger",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1,
      "position": [
        220,
        320
      ]
    },
    {
      "parameters": {
        "jsCode": "const i = $json || {};\nconst zalo_user_id = String(i.zalo_user_id || '').trim();\nif (!zalo_user_id) throw new Error('zalo_user_id required');\nconst action = String(i.action || '').trim();\nconst text = String(i.text || '').trim();\nreturn [{ json: { zalo_user_id, action, text } }];"
      },
      "id": "2",
      "name": "Validate Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        450,
        320
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT * FROM user_sessions\nWHERE zalo_user_id='{{$json.zalo_user_id}}'\n  AND session_state IN ('waiting_for_price_confirm','waiting_for_custom_price')\n  AND expires_at > NOW()\nORDER BY updated_at DESC\nLIMIT 1;"
      },
      "id": "3",
      "name": "Load Pricing Session",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        700,
        320
      ],
      "credentials": {
        "postgres": {
          "id": "__SET_IN_N8N__",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const s = $json;\nif (!s || !s.context_data) throw new Error('No active pricing session');\nconst ctx = typeof s.context_data === 'string' ? JSON.parse(s.context_data) : s.context_data;\nreturn [{ json: { session_id: s.id, zalo_user_id: s.zalo_user_id, session_state: s.session_state, context: ctx, action: $('Validate Input').item.json.action, text: $('Validate Input').item.json.text } }];"
      },
      "id": "4",
      "name": "Extract Session",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        940,
        320
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "version": 2
          },
          "conditions": [
            {
              "id": "custom-text-mode",
              "leftValue": "={{$json.session_state}}",
              "rightValue": "waiting_for_custom_price",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "5",
      "name": "Is waiting_for_custom_price?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        1170,
        320
      ]
    },
    {
      "parameters": {
        "jsCode": "// Shared validate_input pattern (type=price)\nconst raw = String($json.text || '').trim();\nconst price = Number(raw.replace(',', '.'));\nconst minPrice = Number($env.MIN_CUSTOM_PRICE || 100);\nconst maxPrice = Number($env.MAX_CUSTOM_PRICE || 1000000000);\nif (!Number.isFinite(price) || price < minPrice || price > maxPrice) {\n  return [{ json: { ...$json, invalid_custom_price: true, validation_reason: `Price must be between ${minPrice} and ${maxPrice}` } }];\n}\nconst pending = $json.context.pending_custom || {};\nif (!pending.product_id) {\n  throw new Error('Missing product_id in pending custom price context');\n}\nreturn [{ json: { ...$json, invalid_custom_price: false, update_target: { product_id: pending.product_id, new_price: price } } }];"
      },
      "id": "6",
      "name": "Parse Custom Price",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1410,
        220
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "version": 2
          },
          "conditions": [
            {
              "id": "invalid-custom",
              "leftValue": "={{$json.invalid_custom_price}}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "7",
      "name": "Custom Price Valid?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        1640,
        220
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://openapi.zalo.me/v3.0/oa/message/cs",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{$env.ZALO_OA_ACCESS_TOKEN}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { recipient: { user_id: $json.zalo_user_id }, message: { text: 'Giá không hợp lệ. Sếp nhập số dương (VD: 12500).' } } }}"
      },
      "id": "8",
      "name": "Reply Invalid Custom Price",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1860,
        160
      ]
    },
    {
      "parameters": {
        "jsCode": "const action = $json.action;\nconst alerts = Array.isArray($json.context.alerts) ? $json.context.alerts : [];\nconst first = alerts[0] || {};\nif (!action) throw new Error('action required when waiting_for_price_confirm');\nif (action === 'PRICE_CONFIRM') return [{ json: { ...$json, decision: 'confirm', update_target: { product_id: first.product_id, new_price: first.expected_min } } }];\nif (action === 'PRICE_KEEP') return [{ json: { ...$json, decision: 'keep' } }];\nif (action === 'PRICE_CUSTOM') return [{ json: { ...$json, decision: 'custom', update_target: { product_id: first.product_id, suggested_price: first.expected_min } } }];\nthrow new Error('Unsupported action');"
      },
      "id": "9",
      "name": "Resolve Button Action",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1410,
        420
      ]
    },
    {
      "parameters": {
        "conditions": {
