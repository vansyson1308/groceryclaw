{
  "name": "Session Cleanup Cron",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "minutes",
              "minutesInterval": 15
            }
          ]
        }
      },
      "id": "1",
      "name": "Schedule Every 15m",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [260, 280]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE user_sessions\nSET session_state='idle',\n    context_data='{}'::jsonb,\n    expires_at=NULL,\n    updated_at=NOW()\nWHERE expires_at IS NOT NULL\n  AND expires_at < NOW()\n  AND session_state <> 'idle';"
      },
      "id": "2",
      "name": "Expire Stale Sessions",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [520, 280],
