          "id": "__SET_IN_N8N__",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO invoice_log (zalo_user_id, supplier_code, source_type, source_url, parsed_data, status, created_at) VALUES ('system', 'session_cleanup', 'xml', 'workflow://session_cleanup_cron', jsonb_build_object('event','cleanup_run'), 'completed', NOW());"
      },
      "id": "3",
      "name": "Log Cleanup Run",
      "type": "n8n-nodes-base.postgres",
