{
  "name": "Session Handler Barcode Tier3",
  "nodes": [
    {
      "parameters": {},
      "id": "1",
      "name": "Execute Workflow Trigger",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1,
      "position": [
        220,
        320
      ]
    },
    {
      "parameters": {
        "jsCode": "// Shared validate_input pattern (type=barcode)\nconst input = $json || {};\nconst zalo_user_id = String(input.zalo_user_id || '').trim();\nconst barcode = String(input.barcode || input.text || '').trim();\nif (!zalo_user_id) throw new Error('zalo_user_id required');\n\nconst isValid = /^\\d{8,13}$/.test(barcode);\nif (!isValid) {\n  return [{ json: { status: 'invalid_barcode', message: 'Barcode must be 8-13 digits', zalo_user_id } }];\n}\n\nreturn [{ json: { zalo_user_id, barcode } }];"
      },
      "id": "2",
      "name": "Validate Barcode Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        460,
        320
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "version": 2
          },
          "conditions": [
            {
              "id": "invalid",
              "leftValue": "={{$json.status}}",
              "rightValue": "invalid_barcode",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "3",
      "name": "Invalid Barcode?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        700,
        320
      ]
