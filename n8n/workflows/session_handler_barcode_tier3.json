    {
      "parameters": {
        "method": "POST",
        "url": "https://public.kiotviet.vn/api/products",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{$json.access_token}}"
            },
            {
              "name": "Retailer",
              "value": "={{$env.KIOTVIET_RETAILER}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { code: 'SP_AUTO_' + Date.now(), name: $('Extract Barcode Context').item.json.context.pending_item.item_name || 'SP mới', categoryId: Number($env.KIOTVIET_DEFAULT_CATEGORY_ID || 0), barCode: $('Extract Barcode Context').item.json.barcode, basePrice: 0, cost: Number($('Extract Barcode Context').item.json.context.pending_item.unit_price || 0), allowsSale: true, unit: $('Extract Barcode Context').item.json.context.pending_item.unit || 'Cái', description: 'Auto-created via KiotViet-Taphoa Bot', inventories: [{ branchId: Number($env.KIOTVIET_BRANCH_ID || 1), onHand: 0 }] } }}"
      },
      "id": "10",
      "name": "Create KiotViet Product (Tier3)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2100,
        520
      ]
    },
    {
      "parameters": {
        "jsCode": "const ctx = $('Extract Barcode Context').item.json;\nconst cache = $input.item.json;\nlet productId = cache.kiotviet_product_id || cache.id || null;\nlet productCode = cache.product_code || cache.code || null;\nlet productName = cache.product_name || cache.name || ctx.context.pending_item.item_name;\n\nif (!productId) {\n  const created = $('Create KiotViet Product (Tier3)').item?.json || {};\n  productId = created.id || created.data?.id;\n  productCode = created.code || created.data?.code || productCode;\n  productName = created.name || created.data?.name || productName;\n}\nif (!productId) throw new Error('Could not resolve product for barcode tier3');\n\nconst pending = ctx.context.pending_item || {};\nconst supplierUnit = String(pending.unit || '');\nconst posUnit = String(pending.unit || '');\nlet rate = Number(ctx.context.conversion_rate || 1);\nif (!Number.isFinite(rate) || rate <= 0) rate = 1;\n\nreturn [{ json: { ...ctx, resolved: { productId, productCode, productName, supplierUnit, posUnit, rate } } }];"
      },
      "id": "11",
      "name": "Resolve Product + Conversion Context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2330,
        420
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "version": 2
          },
          "conditions": [
            {
              "id": "need-rate",
              "leftValue": "={{$json.resolved.supplierUnit !== $json.resolved.posUnit && $json.resolved.rate === 1}}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "12",
      "name": "Need Conversion Rate?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        2560,
        420
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO mapping_dictionary (\n  supplier_code, supplier_item_code, supplier_item_name,\n  kiotviet_product_id, kiotviet_product_code, kiotviet_product_name,\n  barcode, supplier_unit, pos_unit, conversion_rate,\n  source, is_active, updated_at\n) VALUES (\n  '{{$json.context.supplier_code || 'UNKNOWN_SUPPLIER'}}',\n  '{{$json.context.pending_item.supplier_item_code}}',\n  '{{$json.context.pending_item.item_name}}',\n  {{$json.resolved.productId}},\n  '{{$json.resolved.productCode || ''}}',\n  '{{$json.resolved.productName || ''}}',\n  '{{$json.barcode}}',\n  '{{$json.resolved.supplierUnit}}',\n  '{{$json.resolved.posUnit}}',\n  {{$json.resolved.rate}},\n  'barcode_scan',\n  TRUE,\n  NOW()\n)\nON CONFLICT (supplier_code, supplier_item_code)\nDO UPDATE SET\n  kiotviet_product_id = EXCLUDED.kiotviet_product_id,\n  kiotviet_product_code = EXCLUDED.kiotviet_product_code,\n  kiotviet_product_name = EXCLUDED.kiotviet_product_name,\n  barcode = EXCLUDED.barcode,\n  supplier_unit = EXCLUDED.supplier_unit,\n  pos_unit = EXCLUDED.pos_unit,\n  conversion_rate = EXCLUDED.conversion_rate,\n  source = 'barcode_scan',\n  is_active = TRUE,\n  updated_at = NOW();"
      },
      "id": "13",
      "name": "Upsert mapping_dictionary barcode_scan",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        2790,
        320
      ],
      "credentials": {
        "postgres": {
          "id": "__SET_IN_N8N__",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE user_sessions\nSET session_state='waiting_for_conversion_rate',\n    context_data = jsonb_set(context_data, '{barcode}', to_jsonb('{{$json.barcode}}'::text), true),\n    expires_at=NOW() + INTERVAL '30 minutes',\n    updated_at=NOW()\nWHERE id={{$json.session_id}};"
      },
      "id": "14",
      "name": "Set waiting_for_conversion_rate",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        2790,
