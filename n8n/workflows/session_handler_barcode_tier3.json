    {
      "parameters": {
        "method": "POST",
        "url": "https://openapi.zalo.me/v3.0/oa/message/cs",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{$env.ZALO_OA_ACCESS_TOKEN}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { recipient: { user_id: $json.zalo_user_id }, message: { text: 'Barcode không hợp lệ. Sếp gửi lại mã gồm 8-13 chữ số nhé.' } } }}"
      },
      "id": "4",
      "name": "Reply Invalid Barcode",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        930,
        200
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT *\nFROM user_sessions\nWHERE zalo_user_id='{{$json.zalo_user_id}}'\n  AND session_state IN ('waiting_for_barcode','waiting_for_conversion_rate')\n  AND expires_at > NOW()\nORDER BY updated_at DESC\nLIMIT 1;"
      },
      "id": "5",
      "name": "Load Barcode Session",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        930,
        420
      ],
      "credentials": {
        "postgres": {
          "id": "__SET_IN_N8N__",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const s = $json;\nif (!s || !s.context_data) throw new Error('No active waiting_for_barcode session');\nconst ctx = typeof s.context_data === 'string' ? JSON.parse(s.context_data) : s.context_data;\nreturn [{ json: { session_id: s.id, zalo_user_id: s.zalo_user_id, barcode: $('Validate Barcode Input').item.json.barcode, context: ctx, pending_invoice: s.pending_invoice } }];"
      },
      "id": "6",
      "name": "Extract Barcode Context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1170,
        420
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT * FROM kiotviet_product_cache WHERE barcode='{{$json.barcode}}' LIMIT 1;"
      },
      "id": "7",
      "name": "Find Cached Product by Barcode",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        1410,
        420
      ],
      "credentials": {
        "postgres": {
          "id": "__SET_IN_N8N__",
          "name": "Postgres account"
        }
