        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { recipient: { user_id: $json.zalo_user_id }, message: { text: `Sếp ơi, 1 ${$json.resolved.supplierUnit} có bao nhiêu ${$json.resolved.posUnit}? Gửi giúp em 1 con số.` } } }}"
      },
      "id": "15",
      "name": "Ask Conversion Rate",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        3020,
        520
      ]
    },
    {
      "parameters": {
        "jsCode": "const ctx = $json;\nconst pending = ctx.context.pending_item;\nconst mapped_so_far = Array.isArray(ctx.context.mapped_so_far) ? ctx.context.mapped_so_far : [];\nmapped_so_far.push({\n  ...pending,\n  kiotviet_product_id: ctx.resolved.productId,\n  kiotviet_product_code: ctx.resolved.productCode,\n  kiotviet_product_name: ctx.resolved.productName,\n  conversion_rate: ctx.resolved.rate,\n  converted_qty: Number(pending.quantity || 0) * Number(ctx.resolved.rate || 1),\n  converted_unit_price: pending.is_promotion ? 0 : Number(pending.unit_price || 0) / Number(ctx.resolved.rate || 1)\n});\nreturn [{ json: { ...ctx, mapped_so_far, remaining_items: ctx.context.remaining_items || [] } }];"
      },
