      "parameters": {
        "conditions": {
          "options": {
            "version": 2
          },
          "conditions": [
            {
              "id": "has-cache",
              "leftValue": "={{$json.kiotviet_product_id}}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "larger"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "8",
      "name": "Product Exists?",
      "type": "n8n-nodes-base.if",
