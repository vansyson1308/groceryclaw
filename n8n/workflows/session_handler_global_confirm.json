        "operation": "executeQuery",
        "query": "UPDATE user_sessions\nSET session_state='waiting_for_barcode',\n    context_data=jsonb_set(context_data, '{pending_item}', context_data->'pending_item', true),\n    expires_at=NOW() + INTERVAL '30 minutes',\n    updated_at=NOW()\nWHERE id={{$('Extract Session Context').item.json.session_id}};"
      },
