          "mode": "list"
        },
        "workflowInputs": {
          "mappingMode": "defineBelow",
          "value": {
            "zalo_user_id": "={{$json.zalo_user_id}}",
            "zalo_msg_id": "={{$json.zalo_msg_id}}",
            "channel": "={{$json.channel}}",
            "source_type": "={{$json.source_type}}",
            "source_url": "={{$json.source_url}}",
            "file_url": "={{$json.file_url}}",
            "xml_text": "={{$json.xml_text}}"
          }
        }
      },
      "id": "12",
      "name": "Execute XML Parse Core",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1.2,
      "position": [1900, 360]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO ops_events (ts, level, workflow, event_type, message, context) VALUES (NOW(), 'info', 'telegram_ingress_router', 'text_event', 'Telegram text/callback routed to session layer', jsonb_build_object('sender_id', '{{$json.sender_id}}', 'msg_id', '{{$json.msg_id}}'));"
      },
      "id": "13",
