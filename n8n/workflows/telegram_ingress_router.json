      "id": "10",
      "name": "Download XML Binary",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1420, 360]
    },
    {
      "parameters": {
        "jsCode": "const env = $('Normalize Telegram Envelope').item.json;\nconst bin = $binary.data;\nif (!bin?.data) throw new Error('Telegram XML binary missing');\nconst xml_text = Buffer.from(bin.data, 'base64').toString('utf8');\nreturn [{ json: {\n  zalo_user_id: env.sender_id,\n  zalo_msg_id: env.msg_id,\n  channel: 'telegram',\n  source_type: 'telegram_xml',\n  source_url: `telegram:file_id:${env.file_id}`,\n  file_url: '',\n  xml_text\n} }];"
      },
      "id": "11",
