      },
      "id": "5",
      "name": "Telegram Get File (Photo)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1180, 180]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://api.telegram.org/file/bot{{$env.TELEGRAM_BOT_TOKEN}}/{{$json.result.file_path}}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "file"
            }
          }
        }
      },
      "id": "6",
      "name": "Download Photo Binary",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1420, 180]
    },
    {
      "parameters": {
        "jsCode": "const env = $('Normalize Telegram Envelope').item.json;\nconst bin = $binary.data;\nif (!bin?.data) throw new Error('Telegram photo binary missing');\nconst dataUrl = `data:${bin.mimeType || 'image/jpeg'};base64,${bin.data}`;\nreturn [{ json: {\n  zalo_user_id: env.sender_id,\n  zalo_msg_id: env.msg_id,\n  channel: 'telegram',\n  source_type: 'telegram_image',\n  source_url: `telegram:file_id:${env.file_id}`,\n  image_url: dataUrl,\n  supplier_hint: null\n} }];"
      },
      "id": "7",
      "name": "Build Vision Input Envelope",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1660, 180]
    },
    {
