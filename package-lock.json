{
  "name": "groceryclaw",
  "version": "0.1.0-rc.1",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "groceryclaw",
      "version": "0.1.0-rc.1",
      "workspaces": [
        "apps/*",
        "packages/*"
      ],
      "dependencies": {
        "pg": "^8.13.1"
      },
      "devDependencies": {
        "fast-glob": "^3.3.2",
        "typescript": "^5.9.3"
      },
      "engines": {
        "node": ">=20"
      }
    },
    "apps/admin": {
      "name": "@groceryclaw/admin",
      "version": "0.1.0-rc.1",
      "dependencies": {
        "@groceryclaw/common": "file:../../packages/common"
      }
    },
    "apps/gateway": {
      "name": "@groceryclaw/gateway",
      "version": "0.1.0-rc.1",
      "dependencies": {
        "@groceryclaw/common": "file:../../packages/common"
      }
    },
    "apps/worker": {
      "name": "@groceryclaw/worker",
      "version": "0.1.0-rc.1",
      "dependencies": {
        "@groceryclaw/common": "file:../../packages/common"
      }
    },
    "node_modules/@groceryclaw/admin": {
      "resolved": "apps/admin",
      "link": true
    },
    "node_modules/@groceryclaw/common": {
      "resolved": "packages/common",
      "link": true
    },
    "node_modules/@groceryclaw/gateway": {
      "resolved": "apps/gateway",
      "link": true
    },
    "node_modules/@groceryclaw/worker": {
      "resolved": "apps/worker",
      "link": true
    },
    "node_modules/fast-glob": {
      "version": "3.3.2",
      "dev": true,
      "license": "MIT"
    },
    "node_modules/pg": {
      "version": "8.13.1",
      "license": "MIT"
    },
    "node_modules/typescript": {
      "version": "5.9.3",
      "resolved": "https://registry.npmjs.org/typescript/-/typescript-5.9.3.tgz",
      "integrity": "sha512-jl1vZzPDinLr9eUt3J/t7V6FgNEw9QjvBPdysz9KfQDD41fQrC2Y4vKQdiaUpFT4bXlb1RHhLpp8wtm6M5TgSw==",
      "dev": true,
      "license": "Apache-2.0",
      "bin": {
        "tsc": "bin/tsc",
        "tsserver": "bin/tsserver"
      },
      "engines": {
        "node": ">=14.17"
      }
    },
    "packages/common": {
      "name": "@groceryclaw/common",
      "version": "0.1.0-rc.1"
    }
  }
}
