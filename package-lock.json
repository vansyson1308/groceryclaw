{
  "name": "groceryclaw",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "groceryclaw",
      "version": "0.1.0",
      "workspaces": [
        "apps/*",
        "packages/*"
      ],
      "devDependencies": {
        "typescript": "^5.6.3"
      },
      "engines": {
        "node": ">=20"
      }
    },
    "apps/admin": {
      "name": "@groceryclaw/admin",
      "version": "0.1.0",
      "dependencies": {
        "@groceryclaw/common": "0.1.0"
      }
    },
    "apps/gateway": {
      "name": "@groceryclaw/gateway",
      "version": "0.1.0",
      "dependencies": {
        "@groceryclaw/common": "0.1.0"
      }
    },
    "apps/worker": {
      "name": "@groceryclaw/worker",
      "version": "0.1.0",
      "dependencies": {
        "@groceryclaw/common": "0.1.0"
      }
    },
    "packages/common": {
      "name": "@groceryclaw/common",
      "version": "0.1.0"
    },
    "node_modules/@groceryclaw/admin": {
      "resolved": "apps/admin",
      "link": true
    },
    "node_modules/@groceryclaw/gateway": {
      "resolved": "apps/gateway",
      "link": true
    },
    "node_modules/@groceryclaw/worker": {
      "resolved": "apps/worker",
      "link": true
    },
    "node_modules/@groceryclaw/common": {
      "resolved": "packages/common",
      "link": true
    },
    "node_modules/typescript": {
      "version": "5.6.3",
      "dev": true,
      "license": "Apache-2.0"
    }
  },
  "dependencies": {
    "@groceryclaw/admin": {
      "version": "file:apps/admin"
    },
    "@groceryclaw/gateway": {
      "version": "file:apps/gateway"
    },
    "@groceryclaw/worker": {
      "version": "file:apps/worker"
    },
    "@groceryclaw/common": {
      "version": "file:packages/common"
    },
    "typescript": {
      "version": "5.6.3",
      "dev": true
    }
  }
}
